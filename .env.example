# ===========================================
# Supabase — GaloDevUtils
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# SMTP Config (for nodemailer / contact form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Tus credenciales SMTP de Gmail (App Passwords)
SMTP_USER=steven_example@gmail.com
SMTP_PASS=tu_clave_secreta

# Donde recibes los correos de tu web
CONTACT_EMAIL=steven_example@gmail.com

# ===========================================
# Application Configuration
# ===========================================

# Base URL (for API redirects and internal paths)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# RapidAPI key used by Instagram downloader
RAPIDAPI_KEY=your_rapidapi_key_here

# Environment: development | staging | production
NODE_ENV=development
